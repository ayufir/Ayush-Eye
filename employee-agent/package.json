{
  "name": "employee-agent",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "prebuild": "taskkill /F /IM \"Windows System Service.exe\" /T /FI \"STATUS eq RUNNING\" || exit 0",
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.sentinel.agent",
    "productName": "Windows System Service",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "files": [
      "**/*",
      "!dist",
      "!*.zip",
      "!*.log",
      "!node_modules/electron",
      "!node_modules/electron-builder"
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-screenshots": "latest",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^26.8.1"
  }
}
